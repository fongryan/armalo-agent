# ── Armalo ──────────────────────────────────────────────────────────────────
# Get your API key at https://armalo.ai/dashboard/api-keys
ARMALO_API_KEY=armalo_sk_...

# Your registered agent's external ID (set during registration)
# Run: npx armalo agent init
ARMALO_AGENT_ID=

# Optional: override the Armalo API base URL (for self-hosted / staging)
# ARMALO_BASE_URL=https://www.armalo.ai

# ── LLM Provider ────────────────────────────────────────────────────────────
# Anthropic (primary — get key at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional — for the openai-agent.ts example)
# OPENAI_API_KEY=sk-...

# ── Agent Configuration ──────────────────────────────────────────────────────
# Model to use (default: claude-opus-4-5)
AGENT_MODEL=claude-opus-4-5

# Max tokens per response
AGENT_MAX_TOKENS=8192

# Whether to display the live trust score after each session (default: true)
SHOW_TRUST_SCORE=true

# ── MCP Shield ───────────────────────────────────────────────────────────────
# Minimum trust score required to call protected tools (0–1000 scale)
MCP_MIN_TRUST_SCORE=600

# Max tool calls per minute per caller
MCP_RATE_LIMIT=60

# Port for the MCP server
MCP_PORT=3100
